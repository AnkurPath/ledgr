meta {
  name: Update Account
  type: http
  seq: 6
}

patch {
  url: {{base_url}}/users/setup/accounts/{{account_id}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "HDFC Bank Account Updated",
    "account_type": "Salary",
    "opening_balance": 50,
    "currency": "INR"
  }
  
}
