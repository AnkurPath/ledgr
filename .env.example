## Next.js (public at build/runtime)
# Used by the web app to call the API.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3001

## Rust API
# Bind address for Axum (optional)
LEDGR_API_BIND=127.0.0.1:3001

## Logging (tracing). Set per environment; tower_http controls HTTP request logs.
# Examples: ledgr=debug | tower_http=info | RUST_LOG=error
RUST_LOG=ledgr=info,tower_http=debug

## Postgres
# Example:
# DATABASE_URL=postgres://user:password@host:5432/ledgr?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ledgr

