# Environment: "development" (default) or "production".
# In production, LEDGR_JWT_SECRET_KEY and LEDGR_DATABASE_URL must be set (no fallbacks).
LEDGR_ENV=development

# SQLAlchemy database URL for the FastAPI backend.
LEDGR_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/ledgr

# JWT signing secret. Generate a unique one per environment:
#   python -c "import secrets; print(secrets.token_hex(32))"
LEDGR_JWT_SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Comma-separated list of allowed CORS origins (defaults to http://localhost:3000).
# LEDGR_CORS_ORIGINS=https://app.example.com

# Rate limiting for auth endpoints (slowapi syntax); set enabled=false to turn off.
# LEDGR_RATE_LIMIT_ENABLED=true
# LEDGR_AUTH_RATE_LIMIT=10/minute
